for i, Hat in pairs(char:GetChildren()) do
	if Hat:IsA("Accessory") and Hat:FindFirstChild("Handle") then
        local handle = Hat.Handle
        
        -- Check if this hat is part of our formation list
        local matchIndex = nil
        for idx, formItem in ipairs(availableFormation) do
            if formItem.Name == Hat.Name then
                matchIndex = idx
                break
            end
        end

        if matchIndex then
            local formationInfo = table.remove(availableFormation, matchIndex)
            
            -- Guaranteed Unmesh Logic
            local unmeshed = false
            for _, item in pairs(handle:GetChildren()) do
                if item:IsA("DataModelMesh") or item:IsA("SpecialMesh") or item.Name == "Mesh" then
                    item:Destroy()
                    unmeshed = true
                end
            end
